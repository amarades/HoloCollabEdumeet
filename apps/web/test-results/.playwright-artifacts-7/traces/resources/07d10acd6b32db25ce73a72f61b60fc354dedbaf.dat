export function buildAIContext(participants, sceneObjects, chatHistory, meetingStartTime) {
  const durationMinutes = Math.floor((Date.now() - meetingStartTime) / 6e4);
  const participantNames = participants.map((p) => p.name).join(", ") || "No participants";
  const objectSummary = sceneObjects.slice(0, 8).map(
    (o) => `${o.type}(${o.color}) at [${o.position.map((v) => v.toFixed(1)).join(",")}]${o.lockedBy ? " [locked]" : ""}`
  ).join("; ") || "Empty scene";
  const recentChat = chatHistory.slice(-5).map((m) => `${m.sender}: ${m.text}`).join("\n") || "No recent messages";
  return `You are an AI assistant embedded in a live collaborative video conference called HoloCollabEduMeet.

Current participants (${participants.length}): ${participantNames}
Session duration: ${durationMinutes} minute${durationMinutes !== 1 ? "s" : ""}
3D scene has ${sceneObjects.length} object${sceneObjects.length !== 1 ? "s" : ""}: ${objectSummary}
Recent chat:
${recentChat}

When the user's request involves manipulating the 3D scene, respond with BOTH a natural language explanation AND a JSON block in this exact format:
\`\`\`scene_commands
[{"action":"ADD_OBJECT","type":"box","position":[0,0,0],"color":"#ff0000"}]
\`\`\``;
}
export function parseSceneCommands(aiText) {
  const match = aiText.match(/```scene_commands\s*([\s\S]*?)```/);
  if (!match) return [];
  try {
    return JSON.parse(match[1].trim());
  } catch {
    return [];
  }
}

