# Database Configuration
DATABASE_URL=postgresql+asyncpg://holo_user:holopassword@localhost:5432/holocollab

# AI Service Configuration
AI_SERVICE=mock

# Server Configuration
PORT=8000
HOST=0.0.0.0
RELOAD=True

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Session Configuration
SESSION_SECRET=holocollab-secret-key-change-in-production
SESSION_TIMEOUT=3600

# Storage Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Feature Flags
ENABLE_RECORDING=True
ENABLE_ANALYTICS=True
ENABLE_AI_ASSISTANT=True

DATABASE_URL=postgresql+asyncpg://holo_user:yourpassword@localhost:5432/holocollab
SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">
SESSION_SECRET=<another random string>q
