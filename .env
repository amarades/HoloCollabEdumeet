# Database Configuration
DATABASE_URL=postgresql+asyncpg://holo_user:change-me@localhost:5432/holocollab
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
AUTO_CREATE_TABLES=True

# Environment
ENVIRONMENT=development

# AI Service Configuration
AI_SERVICE=mock

# Server Configuration
PORT=8000
HOST=0.0.0.0
RELOAD=True

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Session and Auth Configuration
SESSION_SECRET=change-me-session-secret
SESSION_TIMEOUT=3600
SECRET_KEY=change-me-jwt-secret
INTERNAL_API_KEY=change-me-internal-api-key

# Storage Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Feature Flags
ENABLE_RECORDING=True
ENABLE_ANALYTICS=True
ENABLE_AI_ASSISTANT=True

# Realtime service config
BACKEND_BASE_URL=http://127.0.0.1:8000
MAX_ROOM_SIZE=12
