# ── Required — no defaults, app will not start without these ──
DATABASE_URL=postgresql+asyncpg://holo_user:yourpassword@localhost:5432/holocollab
SECRET_KEY=replace_with_output_of__python_-c_"import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace_with_another_random_string

# ── AI Service (pick one: mock | openai | gemini | deepseek) ──
AI_SERVICE=mock
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# DEEPSEEK_API_KEY=...

# ── Optional overrides ──
CORS_ORIGIN=http://localhost:5173
ACCESS_TOKEN_EXPIRE_MINUTES=30
