# HoloCollab EduMeet Configuration

# Environment
ENVIRONMENT=development

# AI Service Configuration
AI_SERVICE=mock
# Options: mock, openai, gemini, deepseek

# OpenAI Configuration (if using OpenAI)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4

# Google Gemini Configuration (if using Gemini)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-pro

# DeepSeek Configuration (if using DeepSeek)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_MODEL=deepseek-chat

# Server Configuration
PORT=8000
HOST=0.0.0.0
RELOAD=True

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Session and Auth Configuration
SESSION_SECRET=replace-with-strong-random-session-secret
SECRET_KEY=replace-with-strong-random-jwt-secret
INTERNAL_API_KEY=replace-with-strong-shared-key
SESSION_TIMEOUT=3600

# Database Configuration
DATABASE_URL=postgresql+asyncpg://holo_user:replace-with-strong-password@localhost:5432/holocollab
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
AUTO_CREATE_TABLES=True

# Storage Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# Feature Flags
ENABLE_RECORDING=True
ENABLE_ANALYTICS=True
ENABLE_AI_ASSISTANT=True

# Realtime service config
BACKEND_BASE_URL=http://127.0.0.1:8000
MAX_ROOM_SIZE=50
REDIS_URL=redis://localhost:6379/0
SCENE_STATE_TTL_SECONDS=3600

# LiveKit SFU Configuration (Phase 2)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
WEBRTC_MODE=sfu  # Options: mesh, sfu

# TURN Server Configuration (Phase 3)
TURN_URL=turn:localhost:3478
TURN_USERNAME=turnuser
TURN_PASSWORD=turnpass
EXTERNAL_IP=127.0.0.1

# Multi-server Deployment (Phase 4)
POSTGRES_PASSWORD=change-me-db-password
NGINX_SERVER_NAME=api.holocollab.local
LIVEKIT_SERVER_NAME=livekit.holocollab.local

# Frontend WebRTC config (Vite)
# VITE_REALTIME_WS_URL=ws://127.0.0.1:8002
# VITE_REALTIME_URL=http://127.0.0.1:8002
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:localhost:3478","username":"turnuser","credential":"turnpass"}]
# VITE_TURN_URL=turn:localhost:3478
# VITE_TURN_USERNAME=turnuser
# VITE_TURN_CREDENTIAL=turnpass
# VITE_WEBRTC_ICE_TRANSPORT_POLICY=all
# VITE_LIVEKIT_URL=ws://localhost:7880
# VITE_LIVEKIT_API_KEY=devkey
# VITE_LIVEKIT_API_SECRET=secret
# VITE_WEBRTC_MODE=sfu
# VITE_APP_VERSION=1.0.0
