# Production Environment Configuration for HoloCollab EduMeet
# Copy this file to .env and update the values for your deployment

# ==========================================
# APPLICATION SETTINGS
# ==========================================

# Application domain (required for production)
DOMAIN=your-domain.com

# Environment
NODE_ENV=production
ENVIRONMENT=production

# Session configuration
SESSION_SECRET=your-secure-session-secret-here
SECRET_KEY=your-secure-jwt-secret-here

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=holocollab
POSTGRES_USER=holocollab
POSTGRES_PASSWORD=your-secure-db-password-here

# Database URL (alternative to individual settings)
DATABASE_URL=postgresql://holocollab:your-secure-db-password-here@localhost:5432/holocollab

# ==========================================
# REDIS CONFIGURATION
# ==========================================

# Redis for caching and sessions
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password-here

# Redis URL
REDIS_URL=redis://:your-secure-redis-password-here@localhost:6379

# ==========================================
# LIVEKIT SFU CONFIGURATION
# ==========================================

# LiveKit server URL
LIVEKIT_URL=https://livekit.your-domain.com

# LiveKit API credentials
LIVEKIT_API_KEY=your-livekit-api-key-here
LIVEKIT_API_SECRET=your-livekit-api-secret-here

# LiveKit WebRTC settings
LIVEKIT_WEBRTC_PORT=7880
LIVEKIT_RTMP_PORT=1935

# ==========================================
# TURN/STUN SERVER CONFIGURATION
# ==========================================

# TURN server settings
TURN_SERVER=turn:your-domain.com:3478
TURN_USERNAME=holocollab
TURN_PASSWORD=your-secure-turn-password-here

# STUN server (optional, can use public ones)
STUN_SERVER=stun:stun.l.google.com:19302

# ==========================================
# AI SERVICE CONFIGURATION
# ==========================================

# AI Service URL
AI_SERVICE_URL=http://ai-service:8000

# Ollama configuration (if using local AI)
OLLAMA_HOST=http://ai-service:11434
OLLAMA_MODEL=llama2

# OpenAI API (alternative to local AI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# ==========================================
# CV SERVICE CONFIGURATION
# ==========================================

# Computer Vision Service URL
CV_SERVICE_URL=http://cv-service:8001

# MediaPipe model paths
HAND_MODEL_PATH=/app/models/hand_landmarker.task
GESTURE_MODEL_PATH=/app/models/gesture_recognizer.task

# ==========================================
# BACKEND API CONFIGURATION
# ==========================================

# Backend service URL
BACKEND_URL=http://backend:8002

# API settings
API_HOST=0.0.0.0
API_PORT=8002

# CORS settings
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ==========================================
# REALTIME SERVICE CONFIGURATION
# ==========================================

# WebSocket service URL
REALTIME_URL=http://realtime:8003

# WebSocket settings
WS_HOST=0.0.0.0
WS_PORT=8003

# ==========================================
# SECURITY SETTINGS
# ==========================================

# SSL/TLS settings
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem

# Security headers
SECURITY_HEADERS=true

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ==========================================
# MONITORING & LOGGING
# ==========================================

# Logging level
LOG_LEVEL=INFO

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# Health check endpoint
HEALTH_CHECK_ENABLED=true

# ==========================================
# FILE UPLOAD SETTINGS
# ==========================================

# Upload directory
UPLOAD_DIR=/app/uploads

# Maximum file size (in MB)
MAX_FILE_SIZE=100

# Allowed file types
ALLOWED_EXTENSIONS=pdf,doc,docx,ppt,pptx,xls,xlsx,txt,md

# ==========================================
# EMAIL CONFIGURATION (OPTIONAL)
# ==========================================

# SMTP settings for notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# Email settings
FROM_EMAIL=noreply@your-domain.com
ADMIN_EMAIL=admin@your-domain.com

# ==========================================
# EXTERNAL INTEGRATIONS
# ==========================================

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ==========================================
# PERFORMANCE SETTINGS
# ==========================================

# Worker processes
WORKERS=4

# Connection pool settings
DB_POOL_SIZE=20
REDIS_POOL_SIZE=10

# Cache settings
CACHE_TTL=3600
SESSION_TTL=86400

# ==========================================
# DEVELOPMENT/DEBUG SETTINGS
# ==========================================

# Debug mode (set to false in production)
DEBUG=false

# Development features
DEV_MODE=false

# ==========================================
# BACKUP SETTINGS
# ==========================================

# Backup configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION=7  # Keep 7 days of backups

# ==========================================
# COST OPTIMIZATION
# ==========================================

# Auto-scaling settings
AUTO_SCALE_ENABLED=true
MIN_INSTANCES=2
MAX_INSTANCES=10

# Resource limits
MEMORY_LIMIT=2g
CPU_LIMIT=1.0

# ==========================================
# INTERNAL API KEYS
# ==========================================

# Internal service communication
INTERNAL_API_KEY=your-internal-api-key-here

# Service mesh settings
SERVICE_DISCOVERY_ENABLED=true

# ==========================================
# CLOUD PROVIDER SPECIFIC
# ==========================================

# AWS settings (if using AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# DigitalOcean settings (if using DO)
DO_TOKEN=your-digitalocean-token
DO_REGION=nyc1

# Google Cloud settings (if using GCP)
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_REGION=us-central1

# ==========================================
# ADDITIONAL ENVIRONMENT VARIABLES
# ==========================================

# Add any additional environment variables your application needs